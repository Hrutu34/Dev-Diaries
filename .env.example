# Environment Variables - Development

# Backend Configuration
JAVA_TOOL_OPTIONS=-Xmx512M

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/devdiaries
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DATABASE=devdiaries

# JWT Configuration
APP_JWT_SECRET=devdiariesSecretKeyMakeThisEnvironmentVariableInProduction2024
APP_JWT_EXPIRATION_MS=86400000

# Server Configuration
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000,http://127.0.0.1:4200

# Logging Configuration
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_DEVDIARIES=DEBUG

# Frontend Configuration
API_URL=http://localhost:8080
API_AUTH_BASE=/api/auth

# Email Configuration (for future use)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@devdiaries.com

# Application Environment
APP_ENV=development
APP_DEBUG=true
